# Copy this file to .env and fill in your values.
# Do not commit .env to git.

JUSTTCG_API_KEY=your_justtcg_api_key_here

# Local development (defaults are fine if omitted)
# DEBUG=True
# SECRET_KEY=local-dev-only-key

# Railway / production (set these in Railway Variables)
# DEBUG=False
# SECRET_KEY=generate-a-long-random-string
# ALLOWED_HOSTS=your-app-name.up.railway.app
# CSRF_TRUSTED_ORIGINS=https://your-app-name.up.railway.app
# DATABASE_URL=          # auto-set when you add PostgreSQL on Railway
